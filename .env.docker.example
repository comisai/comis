# =============================================================================
# Comis Docker Compose Environment
# =============================================================================
#
# Copy to .env in the project root before running: docker compose up
#
# This file configures the Docker containers. For provider API keys and
# channel tokens, either set them here or mount your ~/.comis/.env file
# (see COMIS_ENV_FILE below).
#
# PLATFORM NOTE: Production = Linux host only.
# macOS / Windows Docker Desktop runs in a linuxkit VM whose kernel does
# not allow nested PID-namespace + procfs mounts, which breaks the
# bubblewrap exec sandbox. The container will start and the dashboard
# will work, but the agent's `exec` skill will fail at runtime. Docker
# Desktop is supported for dev/testing only — for production, deploy to
# a real Linux host (bare metal, VPS, or any Linux cloud VM). See
# docs/operations/docker.mdx → Platform Support for details.
# =============================================================================

# ---------------------------------------------------------------------------
# Image Selection
# ---------------------------------------------------------------------------

# Use "comis:local" for local builds, or a registry image for production
COMIS_IMAGE=comis:local
COMIS_WEB_IMAGE=comis-web:local

# ---------------------------------------------------------------------------
# Data & Config Paths (host directories mounted into containers)
# ---------------------------------------------------------------------------

COMIS_DATA_DIR=~/.comis
COMIS_CONFIG_DIR=~/.comis
COMIS_ENV_FILE=~/.comis/.env

# ---------------------------------------------------------------------------
# Network Binding
# ---------------------------------------------------------------------------

# 127.0.0.1 = localhost only, 0.0.0.0 = all interfaces
COMIS_GATEWAY_HOST=127.0.0.1
COMIS_GATEWAY_PORT=4766
COMIS_WEB_HOST=127.0.0.1
COMIS_WEB_PORT=8080

# ---------------------------------------------------------------------------
# Security
# ---------------------------------------------------------------------------

# Gateway bearer auth token — generate with: openssl rand -hex 32
COMIS_GATEWAY_TOKEN=

# Secrets storage mode (LEAVE EMPTY for the default Docker setup):
#   Empty (legacy mode, recommended for Docker)
#     Provider keys + channel tokens are read from this .env file (and from
#     compose's `environment:` pass-through). Simple, no encryption key to
#     manage. The daemon-side secrets.db is NOT created.
#
#   Set to a 32-byte hex/base64 value (encrypted-at-rest mode, opt-in)
#     Generate with: openssl rand -hex 32
#     Enables the encrypted secrets.db at <data dir>/secrets.db. Lets you
#     use SecretRef pointers in config.yaml. Note: storing this key beside
#     the encrypted DB inside the same container provides no additional
#     protection against an in-container compromise — the protection only
#     pays off if you inject SECRETS_MASTER_KEY from a host-level secret
#     manager (Vault, AWS SM, Docker secrets) and never persist it on disk.
#     Lose this value and every entry in secrets.db is unrecoverable.
SECRETS_MASTER_KEY=

# ---------------------------------------------------------------------------
# LLM Providers (at least one required)
# ---------------------------------------------------------------------------

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# GOOGLE_API_KEY=
# GROQ_API_KEY=
# MISTRAL_API_KEY=
# DEEPSEEK_API_KEY=
# XAI_API_KEY=
# TOGETHER_API_KEY=
# CEREBRAS_API_KEY=
# OPENROUTER_API_KEY=

# ---------------------------------------------------------------------------
# Voice & Media (optional)
# ---------------------------------------------------------------------------

# ELEVENLABS_API_KEY=               # ElevenLabs TTS
# DEEPGRAM_API_KEY=                 # Deepgram STT

# ---------------------------------------------------------------------------
# Web Search (optional)
# ---------------------------------------------------------------------------

# SEARCH_API_KEY=                   # Brave Search
# PERPLEXITY_API_KEY=               # Perplexity AI
# TAVILY_API_KEY=                   # Tavily AI
# EXA_API_KEY=                      # Exa neural search
# JINA_API_KEY=                     # Jina reader/search

# ---------------------------------------------------------------------------
# Channel Tokens (at least one required)
# ---------------------------------------------------------------------------

TELEGRAM_BOT_TOKEN=
DISCORD_BOT_TOKEN=
SLACK_BOT_TOKEN=
# SLACK_APP_TOKEN=                  # Socket mode
# SLACK_SIGNING_SECRET=             # HTTP mode
# LINE_CHANNEL_ACCESS_TOKEN=
# LINE_CHANNEL_SECRET=
# IRC_NICKSERV_PASSWORD=
# EMAIL_PASSWORD=
