# =============================================================================
# Comis Environment Variables
# =============================================================================
#
# Copy this file to ~/.comis/.env and fill in the keys you need.
# The daemon reads ~/.comis/.env at startup via loadEnvFile().
# Sensitive variables are scrubbed from process.env after loading.
#
# At minimum, one LLM provider key and one channel token are required.
#
# Do NOT commit real keys to version control.
# =============================================================================

# ---------------------------------------------------------------------------
# Encryption & Security
# ---------------------------------------------------------------------------

# Master key for encrypting secrets.db (AES-256-GCM)
# Generate with: openssl rand -hex 32
# SECRETS_MASTER_KEY=

# Canary token generation seed (auto-derived if unset)
# CANARY_SECRET=

# ---------------------------------------------------------------------------
# LLM Providers (at least one required)
# ---------------------------------------------------------------------------

# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GOOGLE_API_KEY=AIza...
# GROQ_API_KEY=gsk_...
# MISTRAL_API_KEY=
# DEEPSEEK_API_KEY=sk-...
# XAI_API_KEY=xai-...
# TOGETHER_API_KEY=
# CEREBRAS_API_KEY=csk-...
# OPENROUTER_API_KEY=sk-or-...

# ---------------------------------------------------------------------------
# Voice & Media
# ---------------------------------------------------------------------------

# Text-to-speech
# ELEVENLABS_API_KEY=sk_...        # ElevenLabs (premium voices)
#                                   # OpenAI TTS uses OPENAI_API_KEY above

# Speech-to-text
# DEEPGRAM_API_KEY=dg-...          # Deepgram Nova-3
#                                   # OpenAI Whisper uses OPENAI_API_KEY above
#                                   # Groq Whisper uses GROQ_API_KEY above

# Image generation
#                                   # FAL uses config credential mapping
#                                   # OpenAI DALL-E uses OPENAI_API_KEY above

# ---------------------------------------------------------------------------
# Web Search Providers
# ---------------------------------------------------------------------------

# SEARCH_API_KEY=BSA...             # Brave Search
# PERPLEXITY_API_KEY=pplx-...       # Perplexity AI
# TAVILY_API_KEY=tvly-...           # Tavily AI
# EXA_API_KEY=                      # Exa neural search
# JINA_API_KEY=jina_...             # Jina reader/search
#                                   # Grok search uses XAI_API_KEY above

# ---------------------------------------------------------------------------
# Channel Credentials
# ---------------------------------------------------------------------------

# Telegram
# TELEGRAM_BOT_TOKEN=123456:ABC-...
# TELEGRAM_WEBHOOK_SECRET=          # Optional: webhook signature verification

# Discord
# DISCORD_BOT_TOKEN=MTIz...

# Slack
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...          # Socket mode
# SLACK_SIGNING_SECRET=             # HTTP mode

# LINE
# LINE_CHANNEL_ACCESS_TOKEN=
# LINE_CHANNEL_SECRET=

# IRC
# IRC_NICKSERV_PASSWORD=

# Email
# EMAIL_PASSWORD=
# EMAIL_OAUTH_CLIENT_ID=            # OAuth2 alternative to password
# EMAIL_OAUTH_CLIENT_SECRET=
# EMAIL_REFRESH_TOKEN=

# ---------------------------------------------------------------------------
# Infrastructure (usually set via config.yaml instead)
# ---------------------------------------------------------------------------

# COMIS_CONFIG_PATHS=~/.comis/config.yaml
# COMIS_DATA_DIR=~/.comis
# COMIS_GATEWAY_TOKEN=              # Gateway bearer auth token
# COMIS_OFFLINE=                    # Set to 1 to disable external tool provisioning
