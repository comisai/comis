---
import Base from "../layouts/Base.astro";
import Footer from "../components/Footer.astro";

const title = "Context Management - How Comis Cuts LLM Costs by 81%";
const description = "Deep dive into Comis's 8-layer context engine, cache fence system, TTL monotonicity enforcement, adaptive cold-start retention, sub-agent spawn staggering, progressive tool disclosure, and 20 mechanisms that reduce multi-agent pipeline costs.";

const layers = [
  {
    num: 1,
    name: "Thinking Block Cleaner",
    desc: "Strips extended thinking traces from older turns (default: 10 turns), keeping recent reasoning while reclaiming tokens from stale deliberation.",
    saves: "Old reasoning traces",
    when: "Every call",
  },
  {
    num: 2,
    name: "Reasoning Tag Stripper",
    desc: "Strips inline reasoning tags (<think>, <thinking>, <thought>, <antThinking>) from non-Anthropic provider responses persisted in session history. Always active regardless of the current model's reasoning capabilities, since sessions may contain messages from multiple providers.",
    saves: "Inline reasoning traces",
    when: "Every call",
  },
  {
    num: 3,
    name: "History Window",
    desc: "Caps conversation history to the last N user turns (default: 15, configurable per channel). Pair-safe: never splits a tool-call/tool-result pair. Compaction summaries always preserved as anchors.",
    saves: "Old conversation turns",
    when: "Every call",
  },
  {
    num: 4,
    name: "Dead Content Evictor",
    desc: "Uses forward-index O(n) analysis to detect provably superseded tool results. If an agent read a file at turn 5 and again at turn 20, the turn-5 result is replaced with a 50-byte placeholder. Tracks 5 categories: file_read, exec, web, image, error.",
    saves: "Superseded results",
    when: "Every call",
  },
  {
    num: 5,
    name: "Observation Masker",
    desc: "Three-tier masking when total context exceeds 120K characters. Protected tools (memory, file reads) are never masked. Standard tools use a keep window (default: 25 most recent). Ephemeral tools (web searches, fetches) get a shorter keep window (default: 10). Masked entries persist to disk for stable cache prefixes. Hysteresis prevents oscillation: activates at 120K, deactivates below 80K.",
    saves: "Old tool outputs",
    when: "Context > 120K chars",
  },
  {
    num: 6,
    name: "LLM Compaction",
    desc: "Last-resort compression when context exceeds 85% of the model window. Compresses 50+ messages into a structured 9-section summary using a cheaper model (Haiku by default). Three-tier fallback: full summarization, filtered summarization, count-only note.",
    saves: "Entire conversation",
    when: "Context > 85% of window",
  },
  {
    num: 7,
    name: "Rehydration",
    desc: "After compaction, strategically re-injects only what was lost: workspace instructions (AGENTS.md, max 3K chars), recently-accessed files (max 5 files, 8K each), and a resume instruction for seamless continuation.",
    saves: "Re-injects critical context",
    when: "After compaction",
  },
  {
    num: 8,
    name: "Objective Reinforcement",
    desc: "For sub-agents, re-injects the original task objective after compaction so delegated tasks stay on track even through context compression.",
    saves: "Agent goals",
    when: "After compaction",
  },
];

const cacheZones = [
  {
    zone: "System Prompt",
    type: "Static",
    content: "Identity, personality, workspace files, tool definitions, security rules",
    behavior: "Cached - paid once at write rate, then $0.50/MTok on every subsequent call",
  },
  {
    zone: "Dynamic Preamble",
    type: "Per-turn",
    content: "Timestamp, sender metadata, channel context, RAG results, active skills, trust entries",
    behavior: "Prepended to user message - never invalidates the cache prefix",
  },
];

const cacheFenceMechanisms = [
  {
    name: "Cache Fence Index",
    code: "CACHE-20",
    desc: "Tracks the highest cache breakpoint position from each LLM call. On the next turn, context engine layers skip all messages at or below this index - preventing modifications that would invalidate the cached prefix.",
    impact: "Eliminated 36K+ tokens of unnecessary cache invalidation per pipeline turn",
  },
  {
    name: "Trim Offset Translation",
    code: "CACHE-20",
    desc: "The history window trims 100+ messages from the front of the session, shifting all indices. The fence index is stored in pre-trim space and correctly adjusted after trimming so protection survives across turns.",
    impact: "Fixed fence being zeroed out by 97-120 message trims",
  },
  {
    name: "Sub-Agent Spawn Staggering",
    code: "CACHE-21",
    desc: "Concurrent sub-agents in a pipeline wave are staggered by 4 seconds. The first sub-agent populates the shared cache prefix (system prompt + tools), then siblings read it instead of each paying the write cost.",
    impact: "49K avg cache reads on sub-agent first turn (shared prefix)",
  },
  {
    name: "Adaptive Cold-Start Retention",
    code: "CACHE-23",
    desc: "Parent agents write at 1h TTL from the first call so the system prompt survives pipeline gaps (>5m). Sub-agents inherit mixed 5m/1h TTLs - shared prefix blocks use the first writer's TTL, conversation-specific content uses 5m. Cache refreshes don't upgrade TTL, so the initial write determines the cache lifetime.",
    impact: "Eliminates re-writes per pipeline gap. 81% cost reduction at steady state.",
  },
  {
    name: "TTL Monotonicity Enforcement",
    code: "CACHE-23",
    desc: "Anthropic's API requires cache breakpoint TTLs to be non-increasing (system >= tools >= messages). The SDK sets system to 5m, but tool breakpoints escalate to 1h. Comis upgrades system block TTLs in the onPayload hook to satisfy the constraint, preventing silent downgrades.",
    impact: "Unlocked 1h cache writes for the first time. Without this, all 1h TTLs were silently downgraded to 5m.",
  },
  {
    name: "Breakpoint Threshold Tuning",
    code: "CACHE-20/23",
    desc: "Sub-agents use 512-token minimum for breakpoint placement. Parent agents use 1,024 tokens (lowered from 4,096). Enables message-level cache breakpoints in conversational exchanges where individual messages are 500-2000 tokens.",
    impact: "Sub-agent cache ratio improved from 3.0x to 4.7x. Parent agent gained 1 message breakpoint per call (was 0).",
  },
];

const pricingTiers = [
  { model: "Claude Opus 4.6", input: "$5.00", write5m: "$6.25", write1h: "$10.00", read: "$0.50", output: "$25.00", readSaving: "10x cheaper" },
  { model: "Claude Sonnet 4.6", input: "$3.00", write5m: "$3.75", write1h: "$6.00", read: "$0.30", output: "$15.00", readSaving: "10x cheaper" },
  { model: "Claude Haiku 4.5", input: "$1.00", write5m: "$1.25", write1h: "$2.00", read: "$0.10", output: "$5.00", readSaving: "10x cheaper" },
];

const microcompaction = [
  { tool: "file_read", threshold: "15,000 chars", reason: "Code context is high-value" },
  { tool: "MCP tools", threshold: "15,000 chars", reason: "MCP responses tend to be verbose" },
  { tool: "Default tools", threshold: "8,000 chars", reason: "Standard inline limit" },
  { tool: "Hard cap", threshold: "100,000 chars", reason: "Truncated before offload" },
];

const budgets = [
  { scope: "Per-execution", default_val: "200K tokens", purpose: "Prevent runaway single calls" },
  { scope: "Per-hour", default_val: "1M tokens", purpose: "Rate limiting" },
  { scope: "Per-day", default_val: "5M tokens", purpose: "Daily cost ceiling" },
];

const realCosts = [
  { op: 'First "Hello"', cost: "$0.25", note: "Cold cache - full system prompt write (Opus)" },
  { op: "Second message", cost: "$0.03", note: "Warm cache - fence protects prefix" },
  { op: "Subsequent messages", cost: "$0.04-0.09", note: "Stable cache reads, fence active" },
  { op: "8-agent trading pipeline", cost: "~$2.11", note: "4 analysts + debate + trader + risk + PM (788K tokens, 70% cache effectiveness)" },
  { op: "Pipeline without optimizations", cost: "~$22.51", note: "Same pipeline, no caching" },
];

// Real production data from daemon logs - April 11, 2026 (76-call session, 2 cache breaks from skill hot-loading)
const realExample = {
  date: "April 11, 2026",
  input: { tokens: 62, rate: 5.00, cost: 0.00 },
  output: { tokens: 20662, rate: 25.00, cost: 0.52 },
  cacheWrite1h: { tokens: 289900, rate: 7.11, cost: 2.06 },
  cacheRead: { tokens: 4892893, rate: 0.50, cost: 2.45 },
  total: { tokens: 5213517, cost: 5.02 },
  withoutCaching: 26.42,
  savings: 81,
  readWriteRatio: 16.9,
};
---

<Base title={title} description={description}>
  <main>
    <!-- Hero -->
    <section class="relative overflow-hidden px-6 pt-32 pb-16 md:pt-40 md:pb-20">
      <div class="absolute inset-0 pointer-events-none">
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-teal/5 rounded-full blur-[120px]"></div>
      </div>

      <div class="relative max-w-3xl mx-auto text-center">
        <a href="/" class="inline-flex items-center gap-1 text-sm text-muted hover:text-teal transition-colors mb-8">
          &larr; Back to Home
        </a>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold tracking-tight leading-[1.1] text-white">
          How Comis cuts LLM costs by 81%
        </h1>
        <p class="mt-6 text-lg md:text-xl text-muted max-w-2xl mx-auto leading-relaxed">
          8-layer context engine, cache fence system, sub-agent spawn staggering, progressive tool disclosure, and 20 mechanisms - so your agents run indefinitely with predictable costs.
        </p>
      </div>
    </section>

    <!-- Key stat -->
    <section class="px-6 pb-16">
      <div class="max-w-4xl mx-auto">
        <div class="bg-navy-light/80 border border-teal/20 rounded-2xl p-8 md:p-12">
          <div class="grid md:grid-cols-4 gap-8 text-center">
            <div>
              <p class="text-4xl font-bold text-teal font-mono">17x</p>
              <p class="text-muted text-sm mt-2">Cache read/write ratio</p>
            </div>
            <div>
              <p class="text-4xl font-bold text-teal font-mono">94%</p>
              <p class="text-muted text-sm mt-2">Tokens served from cache</p>
            </div>
            <div>
              <p class="text-4xl font-bold text-teal font-mono">93%</p>
              <p class="text-muted text-sm mt-2">Writes are cold-start only</p>
            </div>
            <div>
              <p class="text-4xl font-bold text-teal font-mono">$0.50</p>
              <p class="text-muted text-sm mt-2">Per MTok cached reads</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- The Problem -->
    <section class="px-6 py-16 md:py-24 bg-navy-light/50">
      <div class="max-w-4xl mx-auto">
        <p class="text-coral font-semibold text-sm uppercase tracking-widest mb-4">The problem</p>
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-6">
          Context windows are expensive.
        </h2>
        <div class="grid md:grid-cols-2 gap-6">
          <div class="bg-navy rounded-xl border border-white/5 p-6">
            <p class="text-white font-semibold mb-2">System prompts are large</p>
            <p class="text-muted text-sm leading-relaxed">Identity, instructions, tool definitions, workspace files, and security guardrails easily reach 30-60K tokens.</p>
          </div>
          <div class="bg-navy rounded-xl border border-white/5 p-6">
            <p class="text-white font-semibold mb-2">Conversations grow fast</p>
            <p class="text-muted text-sm leading-relaxed">Tool results (file reads, web fetches, API responses) can be 10-50K tokens each. A 30-turn session with tool use can cost $5-15.</p>
          </div>
          <div class="bg-navy rounded-xl border border-white/5 p-6">
            <p class="text-white font-semibold mb-2">Multi-agent pipelines multiply costs</p>
            <p class="text-muted text-sm leading-relaxed">A 7-agent stock analysis pipeline costs 7x the base rate per message. Without optimization, this becomes prohibitive.</p>
          </div>
          <div class="bg-navy rounded-xl border border-white/5 p-6">
            <p class="text-white font-semibold mb-2">Cache misses are silent killers</p>
            <p class="text-muted text-sm leading-relaxed">Anthropic charges 10-20x more for cache writes ($6.25-10/MTok) than reads ($0.50/MTok). A single modified message in the cached prefix invalidates the entire KV cache.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- 8-Layer Pipeline -->
    <section class="px-6 py-16 md:py-24">
      <div class="max-w-5xl mx-auto">
        <p class="text-teal font-semibold text-sm uppercase tracking-widest mb-4">The solution</p>
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">
          8-layer context engine pipeline
        </h2>
        <p class="text-muted text-lg mb-6 max-w-2xl">
          Every conversation is processed through a composable pipeline of 8 layers before each LLM call. Each layer targets a specific source of token waste.
        </p>
        <p class="text-muted text-sm mb-12 max-w-2xl italic">
          Every layer has a circuit breaker - 3 consecutive failures disables the layer. No single optimization bug can bring down the pipeline.
        </p>

        <div class="space-y-4">
          {layers.map((layer) => (
            <div class="bg-navy-light/80 border border-white/5 rounded-xl overflow-hidden">
              <div class="flex flex-col md:flex-row">
                <div class="md:w-16 shrink-0 flex items-center justify-center py-4 md:py-0 bg-teal/10">
                  <span class="text-teal font-mono font-bold text-lg">{layer.num}</span>
                </div>
                <div class="flex-1 p-6">
                  <div class="flex flex-wrap items-center gap-3 mb-2">
                    <h3 class="text-white font-semibold">{layer.name}</h3>
                    <span class="text-xs font-mono px-2 py-0.5 rounded bg-teal/10 text-teal">{layer.when}</span>
                  </div>
                  <p class="text-muted text-sm leading-relaxed">{layer.desc}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Cache-Stable Prompts -->
    <section class="px-6 py-16 md:py-24 bg-navy-light/50">
      <div class="max-w-5xl mx-auto">
        <p class="text-teal font-semibold text-sm uppercase tracking-widest mb-4">Prompt caching</p>
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">
          Cache-stable prompt architecture
        </h2>
        <p class="text-muted text-lg mb-12 max-w-2xl">
          Anthropic's prompt caching cuts costs 7.5x - but only if the system prompt stays identical across turns. Most frameworks embed timestamps or channel metadata in the system prompt, silently invalidating the cache on every message.
        </p>

        <div class="space-y-4">
          {cacheZones.map((z) => (
            <div class="bg-navy rounded-xl border border-white/5 overflow-hidden">
              <div class="px-6 py-4 border-b border-white/5 flex items-center gap-3">
                <span class={`text-xs font-mono px-2 py-0.5 rounded ${z.type === "Static" ? "bg-teal/10 text-teal" : "bg-coral/10 text-coral"}`}>
                  {z.type}
                </span>
                <h3 class="text-lg font-semibold text-white">{z.zone}</h3>
              </div>
              <div class="grid md:grid-cols-2 divide-y md:divide-y-0 md:divide-x divide-white/5">
                <div class="px-6 py-5">
                  <p class="text-xs font-medium text-muted uppercase tracking-wider mb-2">Content</p>
                  <p class="text-muted-light text-sm leading-relaxed">{z.content}</p>
                </div>
                <div class="px-6 py-5">
                  <p class="text-xs font-medium text-muted uppercase tracking-wider mb-2">Cache behavior</p>
                  <p class="text-muted-light text-sm leading-relaxed">{z.behavior}</p>
                </div>
              </div>
            </div>
          ))}
        </div>

        <div class="mt-8 bg-navy rounded-xl border border-teal/15 p-6">
          <p class="text-white font-semibold mb-2">Six categories kept out of the system prompt</p>
          <p class="text-muted text-sm leading-relaxed">
            Date/time, inbound message metadata, channel context, RAG memory results, active skill content, and sender trust entries. Each would invalidate the entire cache prefix if left inline (CACHE-01 through CACHE-06).
          </p>
        </div>
      </div>
    </section>

    <!-- Cache Fence & Feedback Loop -->
    <section class="px-6 py-16 md:py-24">
      <div class="max-w-5xl mx-auto">
        <p class="text-coral font-semibold text-sm uppercase tracking-widest mb-4">Cache fence system</p>
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">
          Protecting the cached prefix across turns
        </h2>
        <p class="text-muted text-lg mb-6 max-w-3xl">
          Without protection, context engine layers modify messages within the cached region - stripping thinking blocks, masking tool results, evicting dead content. Each modification invalidates Anthropic's KV cache, forcing expensive re-writes. The cache fence prevents this.
        </p>

        <!-- Philosophy callout -->
        <div class="bg-navy rounded-xl border border-teal/20 p-6 mb-12">
          <p class="text-white font-semibold mb-3">Active cache optimization, not passive configuration</p>
          <p class="text-muted text-sm leading-relaxed mb-4">
            Most agent platforms treat caching as a provider feature to configure - a single <code class="text-teal text-xs">cache_control</code> tag on the system message. <strong class="text-white">Comis treats the Anthropic cache as a target architecture to optimize for.</strong> The context engine pipeline is cache-aware: it knows where the cache boundary is and actively prevents modifications within the cached region.
          </p>
          <div class="bg-navy-light/80 rounded-lg p-4 font-mono text-xs text-teal overflow-x-auto">
            <pre class="whitespace-pre">breakpoint callback &rarr; fence index &rarr; layer guards &rarr; trim offset translation
         &uarr;                                                    &darr;
         &larr;&mdash;&mdash;&mdash;&mdash; persisted across execute() calls &mdash;&mdash;&mdash;&mdash;&rarr;</pre>
          </div>
          <p class="text-muted text-sm mt-4 leading-relaxed">
            Multiple feedback loops ensure cache stability across turns, achieving a <span class="text-teal font-semibold font-mono">16.9x</span> read/write ratio in production - meaning for every token written to cache, 17 tokens are served from it at 10x lower cost.
          </p>
        </div>

        <!-- SVG Diagram: Cache Fence Feedback Loop -->
        <div class="bg-navy-light/80 border border-white/5 rounded-2xl p-8 mb-12 overflow-x-auto">
          <p class="text-xs font-mono text-muted mb-6 uppercase tracking-widest">Cache fence feedback loop</p>
          <svg viewBox="0 0 800 340" class="w-full max-w-3xl mx-auto" xmlns="http://www.w3.org/2000/svg">
            <!-- Turn N -->
            <rect x="20" y="30" width="340" height="280" rx="12" fill="#1E293B" stroke="#334155" stroke-width="1"/>
            <text x="190" y="22" text-anchor="middle" fill="#94A3B8" font-size="11" font-family="JetBrains Mono, monospace">TURN N</text>

            <!-- Messages array -->
            <text x="40" y="60" fill="#CBD5E1" font-size="11" font-family="Inter, sans-serif" font-weight="600">Session Messages</text>
            <!-- Protected zone -->
            <rect x="40" y="72" width="200" height="28" rx="4" fill="#06B6D4" fill-opacity="0.15" stroke="#06B6D4" stroke-opacity="0.4" stroke-width="1"/>
            <text x="140" y="90" text-anchor="middle" fill="#06B6D4" font-size="10" font-family="JetBrains Mono, monospace">Protected by fence (0..52)</text>
            <!-- Unprotected zone -->
            <rect x="244" y="72" width="100" height="28" rx="4" fill="#FF6B4A" fill-opacity="0.1" stroke="#FF6B4A" stroke-opacity="0.3" stroke-width="1"/>
            <text x="294" y="90" text-anchor="middle" fill="#FF6B4A" font-size="10" font-family="JetBrains Mono, monospace">Modifiable</text>

            <!-- Context Engine -->
            <rect x="40" y="115" width="304" height="36" rx="6" fill="#0F172A" stroke="#06B6D4" stroke-opacity="0.3" stroke-width="1"/>
            <text x="192" y="137" text-anchor="middle" fill="#CBD5E1" font-size="11" font-family="Inter, sans-serif">Context Engine (8 layers + fence guard)</text>

            <!-- Arrow down -->
            <line x1="192" y1="151" x2="192" y2="170" stroke="#334155" stroke-width="1.5"/>
            <polygon points="192,176 187,170 197,170" fill="#334155"/>

            <!-- Post-CE output -->
            <rect x="40" y="178" width="304" height="28" rx="4" fill="#1E293B" stroke="#334155" stroke-width="1"/>
            <text x="192" y="196" text-anchor="middle" fill="#94A3B8" font-size="10" font-family="JetBrains Mono, monospace">Post-CE output (64 msgs after trim)</text>

            <!-- Arrow down -->
            <line x1="192" y1="206" x2="192" y2="222" stroke="#334155" stroke-width="1.5"/>
            <polygon points="192,228 187,222 197,222" fill="#334155"/>

            <!-- LLM Call -->
            <rect x="80" y="230" width="220" height="36" rx="6" fill="#06B6D4" fill-opacity="0.1" stroke="#06B6D4" stroke-opacity="0.4" stroke-width="1.5"/>
            <text x="190" y="252" text-anchor="middle" fill="#06B6D4" font-size="12" font-family="Inter, sans-serif" font-weight="600">LLM Call + Breakpoints</text>

            <!-- Arrow down from LLM to callback -->
            <line x1="190" y1="266" x2="190" y2="285" stroke="#06B6D4" stroke-opacity="0.5" stroke-width="1.5"/>
            <polygon points="190,291 185,285 195,285" fill="#06B6D4" fill-opacity="0.5"/>

            <!-- Callback box -->
            <rect x="100" y="292" width="180" height="22" rx="4" fill="#06B6D4" fill-opacity="0.08"/>
            <text x="190" y="307" text-anchor="middle" fill="#06B6D4" font-size="9" font-family="JetBrains Mono, monospace">onBreakpointsPlaced(idx=52)</text>

            <!-- Turn N+1 -->
            <rect x="440" y="30" width="340" height="280" rx="12" fill="#1E293B" stroke="#334155" stroke-width="1"/>
            <text x="610" y="22" text-anchor="middle" fill="#94A3B8" font-size="11" font-family="JetBrains Mono, monospace">TURN N+1</text>

            <!-- Seed -->
            <rect x="460" y="55" width="300" height="30" rx="4" fill="#06B6D4" fill-opacity="0.08"/>
            <text x="610" y="74" text-anchor="middle" fill="#06B6D4" font-size="10" font-family="JetBrains Mono, monospace">Seed: fence = 52 + trimOffset(116) = 168</text>

            <!-- Messages with fence -->
            <text x="460" y="105" fill="#CBD5E1" font-size="11" font-family="Inter, sans-serif" font-weight="600">Session Messages (grew by 4)</text>
            <rect x="460" y="117" width="220" height="28" rx="4" fill="#06B6D4" fill-opacity="0.15" stroke="#06B6D4" stroke-opacity="0.4" stroke-width="1"/>
            <text x="570" y="135" text-anchor="middle" fill="#06B6D4" font-size="10" font-family="JetBrains Mono, monospace">Protected (0..168)</text>
            <rect x="684" y="117" width="80" height="28" rx="4" fill="#FF6B4A" fill-opacity="0.1" stroke="#FF6B4A" stroke-opacity="0.3" stroke-width="1"/>
            <text x="724" y="135" text-anchor="middle" fill="#FF6B4A" font-size="10" font-family="JetBrains Mono, monospace">New msgs</text>

            <!-- History window -->
            <rect x="460" y="160" width="300" height="30" rx="4" fill="#0F172A" stroke="#334155" stroke-width="1"/>
            <text x="610" y="179" text-anchor="middle" fill="#94A3B8" font-size="10" font-family="JetBrains Mono, monospace">History window trims 118 from front</text>

            <!-- Arrow down -->
            <line x1="610" y1="190" x2="610" y2="206" stroke="#334155" stroke-width="1.5"/>
            <polygon points="610,212 605,206 615,206" fill="#334155"/>

            <!-- Adjusted fence -->
            <rect x="460" y="214" width="300" height="30" rx="4" fill="#06B6D4" fill-opacity="0.08"/>
            <text x="610" y="233" text-anchor="middle" fill="#06B6D4" font-size="10" font-family="JetBrains Mono, monospace">Adjusted: fence = max(-1, 168-118) = 50</text>

            <!-- Layers -->
            <rect x="460" y="258" width="300" height="36" rx="6" fill="#0F172A" stroke="#06B6D4" stroke-opacity="0.3" stroke-width="1"/>
            <text x="610" y="280" text-anchor="middle" fill="#CBD5E1" font-size="11" font-family="Inter, sans-serif">Layers skip msgs 0..50 (cache preserved)</text>

            <!-- Feedback arrow (curved) -->
