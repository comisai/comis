  ...architectureRows,
  ...securityRows,
  ...extensibilityRows,
  ...agentRows,
  ...contextRows,
  ...cacheRows,
  ...autonomyRows,
  ...testRows,
  ...infraRows,
];

const categories = [
  { name: "Architecture & Code", rows: architectureRows },
  { name: "Security", rows: securityRows },
  { name: "Extensibility", rows: extensibilityRows },
  { name: "Agent Capabilities", rows: agentRows },
  { name: "Context Management", rows: contextRows },
  { name: "Cache & Cost Optimization", rows: cacheRows },
  { name: "Agent Autonomy", rows: autonomyRows },
  { name: "Test Infrastructure", rows: testRows },
  { name: "Infrastructure & DX", rows: infraRows },
];

function count(rows: Row[], v: Verdict) {
  return rows.filter((r) => r.verdict === v).length;
}

const totalComis = count(allRows, "comis");
const totalOpenclaw = count(allRows, "openclaw");
const totalTie = count(allRows, "tie");

function verdictBadge(v: Verdict) {
  if (v === "comis")
    return { text: "Comis", cls: "bg-coral/20 text-coral" };
  if (v === "openclaw")
    return { text: "OpenClaw", cls: "bg-teal/20 text-teal" };
  return { text: "Tie", cls: "bg-white/10 text-muted" };
}

const sectionThemes = [
  { accent: "coral", bg: "bg-navy-light/50" },
  { accent: "coral", bg: "" },
  { accent: "teal", bg: "bg-navy-light/50" },
  { accent: "coral", bg: "" },
  { accent: "coral", bg: "bg-navy-light/50" },
  { accent: "emerald", bg: "" },
  { accent: "emerald", bg: "bg-navy-light/50" },
  { accent: "teal", bg: "" },
  { accent: "purple", bg: "bg-navy-light/50" },
] as const;

const sectionMeta = [
  {
    title: "Architecture & Code",
    subtitle: "Compile-time safety vs runtime flexibility.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />`,
  },
  {
    title: "Security",
    subtitle: "Defense in depth vs boundary enforcement.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />`,
  },
  {
    title: "Extensibility",
    subtitle: "Typed ports vs plugin SDK breadth.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M11 4a2 2 0 114 0v1a1 1 0 001 1h3a1 1 0 011 1v3a1 1 0 01-1 1h-1a2 2 0 100 4h1a1 1 0 011 1v3a1 1 0 01-1 1h-3a1 1 0 01-1-1v-1a2 2 0 10-4 0v1a1 1 0 01-1 1H7a1 1 0 01-1-1v-3a1 1 0 00-1-1H4a2 2 0 110-4h1a1 1 0 001-1V7a1 1 0 011-1h3a1 1 0 001-1V4z" />`,
  },
  {
    title: "Agent Capabilities",
    subtitle: "Fleet isolation, orchestration, and memory.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />`,
  },
  {
    title: "Context Management",
    subtitle: "Built-in pipeline vs pluggable ecosystem.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4" />`,
  },
  {
    title: "Cache & Cost Optimization",
    subtitle: "Active cache optimization vs passive tracking. The fence, the feedback loop, and 81% cost reduction.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />`,
  },
  {
    title: "Agent Autonomy",
    subtitle: "How independently agents operate.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />`,
  },
  {
    title: "Test Infrastructure",
    subtitle: "Volume, tooling, and automation.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" />`,
  },
  {
    title: "Infrastructure & DX",
    subtitle: "Build speed and observability.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />`,
  },
];
---

<Base title={title} description={description}>
  <main>
    <!-- Hero -->
    <section class="relative overflow-hidden px-6 pt-32 pb-12 md:pt-40 md:pb-16">
      <div class="absolute inset-0 pointer-events-none">
        <div
          class="absolute top-1/3 left-1/3 w-[400px] h-[400px] bg-coral/5 rounded-full blur-[120px]"
        ></div>
        <div
          class="absolute top-1/2 right-1/4 w-[300px] h-[300px] bg-teal/5 rounded-full blur-[120px]"
        ></div>
      </div>

      <div class="relative max-w-3xl mx-auto text-center">
        <p
          class="text-sm font-semibold text-muted uppercase tracking-widest mb-4"
        >
          Deep technical comparison
        </p>
        <h1
          class="text-4xl md:text-5xl lg:text-6xl font-extrabold tracking-tight leading-[1.1]"
        >
          <span class="text-white">Comis</span>
          <span class="text-muted mx-2">vs</span>
          <span
            class="bg-gradient-to-r from-teal to-teal-dark bg-clip-text text-transparent"
            >OpenClaw</span
          >
        </h1>
        <p
          class="mt-6 text-lg md:text-xl text-muted max-w-2xl mx-auto leading-relaxed"
        >
          60 dimensions. Both codebases reviewed. Every claim verified by
          independent agents against the actual source code.
        </p>
        <p class="mt-3 text-sm text-muted/70">
          Both projects are open source. This comparison reflects the codebases
          as of April 2026.
        </p>
      </div>
    </section>

    <!-- Scorecard -->
    <section class="px-6 pb-16 md:pb-20">
      <div class="max-w-4xl mx-auto">
        <!-- Total scores -->
        <div class="grid grid-cols-3 gap-6 max-w-lg mx-auto mb-10">
          <div class="text-center">
            <div class="text-5xl md:text-6xl font-extrabold text-coral">
              {totalComis}
            </div>
            <div class="text-sm text-muted mt-1">Comis leads</div>
          </div>
          <div class="text-center">
            <div class="text-5xl md:text-6xl font-extrabold text-teal">
              {totalOpenclaw}
            </div>
            <div class="text-sm text-muted mt-1">OpenClaw leads</div>
          </div>
          <div class="text-center">
            <div class="text-5xl md:text-6xl font-extrabold text-muted/60">
              {totalTie}
            </div>
            <div class="text-sm text-muted mt-1">Tied</div>
          </div>
        </div>

        <!-- Category breakdown -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
          {
            categories.map((cat) => (
              <div class="bg-navy-light/50 rounded-lg border border-white/5 p-4 text-center">
                <div class="text-xs text-muted uppercase tracking-wider mb-2 leading-tight">
                  {cat.name}
                </div>
                <div class="flex items-center justify-center gap-1.5 text-sm font-bold">
                  <span class="text-coral">{count(cat.rows, "comis")}</span>
                  <span class="text-muted/40">&ndash;</span>
                  <span class="text-teal">
                    {count(cat.rows, "openclaw")}
                  </span>
                  <span class="text-muted/40">&ndash;</span>
                  <span class="text-muted/60">{count(cat.rows, "tie")}</span>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- Comparison sections -->
    {
      categories.map((cat, i) => {
        const theme = sectionThemes[i];
        const meta = sectionMeta[i];
        const accentText =
          theme.accent === "coral"
            ? "text-coral"
            : theme.accent === "teal"
              ? "text-teal"
              : theme.accent === "emerald"
                ? "text-emerald-400"
                : "text-purple-400";
        const accentBg =
          theme.accent === "coral"
            ? "bg-coral/20"
            : theme.accent === "teal"
              ? "bg-teal/20"
              : theme.accent === "emerald"
                ? "bg-emerald-500/20"
                : "bg-purple-500/20";

        return (
          <section class:list={["px-6 py-16 md:py-24", theme.bg]}>
            <div class="max-w-5xl mx-auto">
              <div class="flex items-center gap-3 mb-4">
                <div
                  class:list={[
                    "w-8 h-8 rounded-lg flex items-center justify-center",
                    accentBg,
                  ]}
                >
                  <svg
                    class:list={["w-4 h-4", accentText]}
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2"
                    set:html={meta.icon}
                  />
                </div>
                <p
                  class:list={[
                    "font-semibold text-sm uppercase tracking-widest",
                    accentText,
                  ]}
                >
                  {meta.title}
                </p>
              </div>
              <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">
                {meta.subtitle}
              </h2>

              <div class="space-y-5 mt-10">
                {cat.rows.map((r) => {
                  const badge = verdictBadge(r.verdict);
                  return (
                    <div class="bg-navy rounded-xl border border-white/5 overflow-hidden">
                      <div class="px-6 py-4 border-b border-white/5 flex items-center justify-between">
                        <h3 class="text-lg font-semibold text-white">
                          {r.label}
                        </h3>
                        <span
                          class:list={[
                            "text-xs font-semibold px-2.5 py-0.5 rounded-full",
                            badge.cls,
                          ]}
                        >
                          {badge.text}
                        </span>
                      </div>
                      <div class="grid md:grid-cols-2 divide-y md:divide-y-0 md:divide-x divide-white/5">
                        <div
                          class:list={[
                            "px-6 py-5",
                            r.verdict === "openclaw" ? "bg-teal/5" : "",
                          ]}
                        >
                          <p
                            class:list={[
                              "text-xs font-medium uppercase tracking-wider mb-2",
                              r.verdict === "openclaw"
                                ? "text-teal"
                                : "text-muted",
                            ]}
                          >
                            OpenClaw
                          </p>
                          <p
                            class:list={[
                              "leading-relaxed",
                              r.verdict === "openclaw"
                                ? "text-muted-light"
                                : "text-muted",
                            ]}
                          >
                            {r.openclaw}
                          </p>
                        </div>
                        <div
                          class:list={[
                            "px-6 py-5",
                            r.verdict === "comis" ? "bg-coral/5" : "",
                          ]}
                        >
                          <p
                            class:list={[
                              "text-xs font-medium uppercase tracking-wider mb-2",
                              r.verdict === "comis"
                                ? "text-coral"
                                : "text-muted",
                            ]}
                          >
                            Comis
                          </p>
                          <p
                            class:list={[
                              "leading-relaxed",
                              r.verdict === "comis"
                                ? "text-muted-light"
                                : "text-muted",
                            ]}
                          >
                            {r.comis}
                          </p>
                        </div>
                      </div>
                    </div>
                  );
                })}
              </div>
            </div>
          </section>
        );
      })
    }

    <!-- Key takeaways -->
    <section class="px-6 py-16 md:py-24">
      <div class="max-w-5xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-12 text-center">
          Key takeaways
        </h2>

        <div class="grid md:grid-cols-2 gap-8">
          <!-- Where Comis leads -->
          <div
            class="bg-navy-light/50 rounded-xl border border-coral/20 p-8"
          >
            <h3 class="text-xl font-bold text-coral mb-6">
              Where Comis leads
            </h3>
            <ul class="space-y-4 text-muted-light">
              <li>
                <span class="font-semibold text-white">Security (7&ndash;0&ndash;2):</span>
                Prompt injection detection, trust-partitioned memory, output scanning,
                SSRF DNS pinning, and ESLint-enforced secret hygiene. OpenClaw
                explicitly scopes prompt injection out of their security model.
              </li>
              <li>
                <span class="font-semibold text-white">DAG pipelines:</span> Full
                graph execution engine with barrier modes, template interpolation,
                and per-node timeouts. OpenClaw has no DAG support.
              </li>
              <li>
                <span class="font-semibold text-white">Context management (5&ndash;1&ndash;3):</span>
                Built-in 8-layer pipeline with per-layer circuit breakers, proactive compaction at 85%
                with 3-level fallback, write-time microcompaction with disk offloading,
                post-compaction rehydration, and 25% context rot buffer. OpenClaw counters
                with a pluggable ContextEngine slot API and a growing ecosystem
                - lossless-claw scored 74.8 on OOLONG (vs Claude Code's 70.3)
                and the community 12-layer architecture adds facts.db, LightRAG, and
                vector search on top.
              </li>
              <li>
                <span class="font-semibold text-white">Cache &amp; cost optimization (7&ndash;2&ndash;1):</span>
                20 prompt cache optimizations including TTL monotonicity enforcement,
                adaptive cold-start retention, 3-zone breakpoint placement with model-specific
                thresholds, observation masker hysteresis to prevent cache thrashing,
                tool schema snapshotting, and subagent short-TTL economics. Measured
                81.5% cache hit rate in production. OpenClaw counters with persistent
                SQLite embedding cache and broader multi-provider cache awareness.
              </li>
              <li>
                <span class="font-semibold text-white">Agent isolation:</span> Isolated
                executors, budget guards, cost trackers, and skill registries per
                agent vs shared infrastructure with config cascading.
              </li>
              <li>
                <span class="font-semibold text-white">Agent autonomy (4&ndash;0&ndash;2):</span>
                Self-evolving personality via workspace files, task extraction from
                conversations, nuanced group chat intelligence, and self-onboarding
                - agents bootstrap themselves without human hand-holding.
              </li>
            </ul>
          </div>

          <!-- Where OpenClaw leads -->
          <div
            class="bg-navy-light/50 rounded-xl border border-teal/20 p-8"
          >
            <h3 class="text-xl font-bold text-teal mb-6">
              Where OpenClaw leads
            </h3>
            <ul class="space-y-4 text-muted-light">
              <li>
                <span class="font-semibold text-white">Extensibility DX:</span>
                The plugin SDK with 219+ exports and dynamic loader makes adding
                channels and tools lower friction. 40 extension packages demonstrate
                ecosystem maturity.
              </li>
              <li>
                <span class="font-semibold text-white">Channel coverage:</span>
                20 messaging platforms vs 9. Beyond the shared set, OpenClaw adds
                Matrix, MS Teams, Google Chat, Feishu, Mattermost, Twitch, Nostr,
                and more.
              </li>
              <li>
                <span class="font-semibold text-white">Build speed:</span> tsdown
                (esbuild-based) is significantly faster for incremental builds than
                tsc-per-package with composite references.
              </li>
              <li>
                <span class="font-semibold text-white">Context engine ecosystem:</span>
                The pluggable ContextEngine slot API lets third parties replace
                the entire context pipeline. lossless-claw, MemOS Cloud, and the
                community 12-layer architecture demonstrate real ecosystem traction.
              </li>
              <li>
                <span class="font-semibold text-white">Test infrastructure (4&ndash;1&ndash;0):</span>
                2,242 test files, 13 dedicated live-model tests, 7 Docker E2E suites,
                46 browser tests via Playwright, and full GitHub Actions CI with parallel
                lane splitting. Comis counters with ChaosEchoAdapter fault injection
                and structured log validation.
              </li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- Design philosophy -->
    <section class="px-6 py-16 md:py-24 bg-navy-light/50">
      <div class="max-w-5xl mx-auto">
        <h2
          class="text-3xl md:text-4xl font-bold text-white mb-12 text-center"
        >
          Different philosophies
        </h2>

        <div class="grid md:grid-cols-2 gap-8">
          <div class="space-y-6">
            <div class="flex items-center gap-3 mb-2">
              <img
                src="/images/comis-logo.png"
                alt="Comis"
                class="h-6"
              />
              <h3 class="text-lg font-bold text-white">Comis</h3>
            </div>
            <div class="space-y-3 text-muted-light">
              <p>
                <span class="text-white font-medium">Design principle:</span> Correctness
                first - ports, Result types, compile-time safety.
              </p>
              <p>
                <span class="text-white font-medium">Security stance:</span> Defense
                in depth - 7+ security layers, ESLint enforcement, fail-closed
                defaults.
              </p>
              <p>
                <span class="text-white font-medium">Extension model:</span> Implement
                typed interfaces, wire in composition root.
              </p>
              <p>
                <span class="text-white font-medium">Trust model:</span> Multi-tenant
                ready with trust-partitioned memory and per-session routing.
              </p>
            </div>
          </div>

          <div class="space-y-6">
            <div class="flex items-center gap-3 mb-2">
              <div
                class="w-6 h-6 rounded bg-teal/20 flex items-center justify-center"
              >
                <span class="text-teal text-xs font-bold">OC</span>
              </div>
              <h3 class="text-lg font-bold text-white">OpenClaw</h3>
            </div>
            <div class="space-y-3 text-muted-light">
              <p>
                <span class="text-white font-medium">Design principle:</span> Velocity
                first - plugins, dynamic loading, convention over configuration.
              </p>
              <p>
                <span class="text-white font-medium">Security stance:</span> Boundary
                enforcement - sandbox, approval gates, explicit trust model.
              </p>
              <p>
                <span class="text-white font-medium">Extension model:</span> Drop
                a package in extensions/, implement plugin interface, auto-discovered.
              </p>
              <p>
                <span class="text-white font-medium">Trust model:</span> Single-user
                per gateway - an explicit architectural choice.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Summary table -->
    <section class="px-6 py-16 md:py-24">
      <div class="max-w-5xl mx-auto">
        <h2
          class="text-3xl md:text-4xl font-bold text-white mb-4 text-center"
        >
          All 60 dimensions
        </h2>
        <p class="text-muted text-lg mb-12 text-center max-w-xl mx-auto">
          The full picture at a glance.
        </p>

        <div class="overflow-x-auto">
          <table class="w-full text-left">
            <thead>
              <tr class="border-b border-white/10">
                <th scope="col" class="py-3 pr-4 text-sm font-medium text-muted"
                ></th>
                <th
                  scope="col"
                  class="py-3 px-4 text-sm font-medium text-muted"
                  >OpenClaw</th
                >
                <th
                  scope="col"
                  class="py-3 px-4 text-sm font-semibold text-coral"
                  >Comis</th
                >
                <th
                  scope="col"
                  class="py-3 pl-4 text-sm font-medium text-muted text-center"
                  >Winner</th
                >
              </tr>
            </thead>
            <tbody>
              {
                allRows.map((r) => {
                  const badge = verdictBadge(r.verdict);
                  return (
                    <tr class="border-b border-white/5">
                      <th
                        scope="row"
                        class="py-3 pr-4 text-sm font-medium text-white whitespace-nowrap text-left"
                      >
                        {r.label}
                      </th>
                      <td class="py-3 px-4 text-sm text-muted max-w-[220px]">
                        {r.openclaw.split(".")[0]}.
                      </td>
                      <td class="py-3 px-4 text-sm text-muted-light max-w-[220px]">
                        {r.comis.split(".")[0]}.
                      </td>
                      <td class="py-3 pl-4 text-center">
                        <span
                          class:list={[
                            "text-xs font-semibold px-2 py-0.5 rounded-full",
                            badge.cls,
                          ]}
                        >
                          {badge.text}
                        </span>
                      </td>
                    </tr>
                  );
                })
              }
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- Methodology note -->
    <section class="px-6 pb-8">
      <div class="max-w-3xl mx-auto text-center">
        <p class="text-sm text-muted">
          This comparison was created by parallel deep-dive analysis of both
          codebases and verified by 6 independent agents that checked 64 claims
          (32 per codebase) against the actual source code. All corrections have
          been applied.
        </p>
      </div>
    </section>

    <!-- CTA -->
    <section class="px-6 py-16 md:py-24 bg-navy-light/50">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">
          Ready to try Comis?
        </h2>
        <p class="text-muted text-lg mb-10">
          Free, open source, and takes four commands to set up.
        </p>

        <div class="flex flex-wrap gap-4 justify-center">
          <a
            href="https://docs.comis.ai"
            rel="noopener noreferrer"
            target="_blank"
            class="inline-flex items-center justify-center px-8 py-3.5 bg-coral-btn hover:bg-coral-btn-hover text-white font-semibold rounded-lg transition-colors text-lg"
          >
            Get Started
          </a>
          <a
            href="https://github.com/comisai/comis"
