---
import Base from "../layouts/Base.astro";
import Footer from "../components/Footer.astro";

const title = "Architecture - Clean Hexagonal Design for AI Agents";
const description = "13-package TypeScript monorepo with hexagonal architecture. Ports and adapters, Result types, typed event bus, and composition root - built for maintainability and testability.";

const ports = [
  {
    name: "ChannelPort",
    methods: "start, stop, sendMessage, editMessage, reactToMessage, deleteMessage, fetchMessages, sendAttachment",
    adapters: "Discord, Telegram, Slack, WhatsApp, Signal, iMessage, IRC, LINE, Email",
    adapterCount: 9,
  },
  {
    name: "MemoryPort",
    methods: "store, retrieve, search, update, delete, clear",
    adapters: "SqliteMemoryAdapter (FTS5 + vector search)",
    adapterCount: 1,
  },
  {
    name: "SkillPort",
    methods: "validate, execute, manifest",
    adapters: "SkillRegistry (prompt-only), MCP client",
    adapterCount: 2,
  },
  {
    name: "EmbeddingPort",
    methods: "embed, embedBatch, dispose",
    adapters: "Local GGUF (nomic), OpenAI",
    adapterCount: 2,
  },
  {
    name: "MediaResolverPort",
    methods: "resolve",
    adapters: "7 per-platform resolvers, CompositeResolver",
    adapterCount: 8,
  },
  {
    name: "TranscriptionPort",
    methods: "transcribe",
    adapters: "OpenAI Whisper, Groq, Deepgram",
    adapterCount: 3,
  },
  {
    name: "TTSPort",
    methods: "synthesize",
    adapters: "OpenAI, ElevenLabs, Edge TTS",
    adapterCount: 3,
  },
  {
    name: "ImageAnalysisPort",
    methods: "analyze",
    adapters: "Vision analysis providers",
    adapterCount: 1,
  },
  {
    name: "VisionProvider",
    methods: "analyzeImage, analyzeVideo",
    adapters: "Gemini Vision (multi-capability)",
    adapterCount: 1,
  },
  {
    name: "FileExtractionPort",
    methods: "extract",
    adapters: "PDF (pdfjs-dist), CSV, document text",
    adapterCount: 3,
  },
  {
    name: "ImageGenerationPort",
    methods: "generate",
    adapters: "FAL, OpenAI",
    adapterCount: 2,
  },
  {
    name: "OutputGuardPort",
    methods: "scan",
    adapters: "LLM output secret-leak scanner (15 patterns)",
    adapterCount: 1,
  },
  {
    name: "SecretStorePort",
    methods: "get, set, delete, list",
    adapters: "SQLite-backed AES-256-GCM encrypted store",
    adapterCount: 1,
  },
  {
    name: "DeviceIdentityPort",
    methods: "getIdentity, sign, verify",
    adapters: "Ed25519 keypair (filesystem-persisted)",
    adapterCount: 1,
  },
  {
    name: "PluginPort",
    methods: "register, unregister, list",
    adapters: "Plugin registry with lifecycle management",
    adapterCount: 1,
  },
  {
    name: "DeliveryQueuePort",
    methods: "enqueue, dequeue, ack, nack",
    adapters: "SQLite-backed delivery queue",
    adapterCount: 1,
  },
  {
    name: "DeliveryMirrorPort",
    methods: "record, check, prune",
    adapters: "SQLite-backed deduplication mirror",
    adapterCount: 1,
  },
  {
    name: "CredentialMappingPort",
    methods: "get, set, delete, list",
    adapters: "Credential mapping CRUD",
    adapterCount: 1,
  },
];

const packages = [
  { name: "shared", desc: "Result<T,E> type, utilities", deps: "zero", layer: "Foundation" },
  { name: "core", desc: "Ports, domain types, config, security, event bus, hooks", deps: "shared", layer: "Foundation" },
  { name: "infra", desc: "Pino structured logging", deps: "core", layer: "Foundation" },
  { name: "memory", desc: "SQLite + FTS5 + vector search", deps: "core", layer: "Service" },
  { name: "scheduler", desc: "Cron, heartbeat, task extraction", deps: "core", layer: "Service" },
  { name: "skills", desc: "Manifest, MCP, media processing, STT/TTS", deps: "core", layer: "Service" },
  { name: "agent", desc: "Executor, RAG, budget, circuit breaker, sessions", deps: "core, memory, scheduler", layer: "Service" },
  { name: "gateway", desc: "Hono HTTP, JSON-RPC, WebSocket, mTLS", deps: "core", layer: "Adapter" },
  { name: "channels", desc: "9 platform adapters", deps: "core, agent, infra", layer: "Adapter" },
  { name: "daemon", desc: "Orchestrator, observability, systemd", deps: "all packages", layer: "Composition" },
  { name: "cli", desc: "Commander.js, JSON-RPC client", deps: "core, agent", layer: "Adapter" },
  { name: "comis", desc: "Namespace re-exports", deps: "all packages", layer: "Composition" },
  { name: "web", desc: "Lit + Vite + Tailwind SPA", deps: "standalone", layer: "Adapter" },
];

const patterns = [
  {
    name: "Result<T, E>",
    what: "Discriminated union for error handling",
    why: "Eliminates exception-driven control flow. Every function explicitly declares success and failure types. The compiler enforces handling of both paths.",
    example: "ok(value) | err(error) - narrows on result.ok discriminant",
  },
  {
    name: "Factory Functions",
    what: "createXxx() returns typed interface, not class",
    why: "Decouples construction from usage. Dependencies injected as plain objects. Tests can substitute any compatible implementation without class hierarchies.",
    example: "createDiscordAdapter(deps) -> ChannelPort",
  },
  {
    name: "Typed Event Bus",
    what: "Type-safe EventEmitter with EventMap interface",
    why: "Decouples modules without direct imports. Compile-time checking of event names and payload shapes. Wrong payload -> type error.",
    example: "eventBus.emit('context:compacted', { agentId, ... })",
  },
  {
    name: "AsyncLocalStorage Context",
    what: "Request-scoped identity via runWithContext()",
    why: "Flows tenant, user, session, and trace IDs through entire async call chain without parameter drilling. Enables cross-cutting authorization and logging.",
    example: "runWithContext(ctx, async () => { ... getContext().traceId })",
  },
  {
    name: "Zod Schema -> Type",
    what: "Define schema once, infer TypeScript type",
    why: "Single source of truth for validation and types. Runtime validation + compile-time safety. No drift between what you validate and what you use.",
    example: "const Schema = z.object({...}); type T = z.infer<typeof Schema>;",
  },
  {
    name: "Composition Root",
    what: "bootstrap.ts wires the entire application",
    why: "One place creates all dependencies in the right order. Returns AppContainer with typed services. No hidden singletons, no global state, no service locator.",
    example: "bootstrap(paths) -> Result<AppContainer, ConfigError>",
  },
];

const benefits = [
  {
    title: "Swap any adapter without touching core",
    desc: "Want to add Matrix support? Implement ChannelPort. Want to switch from SQLite to Postgres? Implement MemoryPort. The core never changes.",
    icon: "M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15",
  },
  {
    title: "Test anything in isolation",
    desc: "Every port can be mocked with a plain object. No real Discord API needed to test message routing. No real database needed to test memory search. The chaos echo adapter injects faults for integration testing.",
    icon: "M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z",
  },
  {
    title: "Reason about dependencies",
    desc: "The package dependency graph is a strict DAG. shared has zero deps. core depends only on shared. No circular imports. TypeScript project references enforce build order.",
    icon: "M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zM16 13a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z",
  },
  {
    title: "Extend without modifying",
    desc: "The plugin system lets you add hooks, tools, HTTP routes, and config schemas without touching core code. Priority ordering controls execution order. Plugin lifecycle is centralized.",
    icon: "M17 14v6m-3-3h6M6 10h2a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v2a2 2 0 002 2zm10 0h2a2 2 0 002-2V6a2 2 0 00-2-2h-2a2 2 0 00-2 2v2a2 2 0 002 2zM6 20h2a2 2 0 002-2v-2a2 2 0 00-2-2H6a2 2 0 00-2 2v2a2 2 0 002 2z",
  },
];
---

<Base title={title} description={description}>
  <main>
    <!-- Hero -->
    <section class="relative overflow-hidden px-6 pt-32 pb-16 md:pt-40 md:pb-20">
      <div class="absolute inset-0 pointer-events-none">
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-teal/5 rounded-full blur-[120px]"></div>
      </div>

      <div class="relative max-w-3xl mx-auto text-center">
        <a href="/" class="inline-flex items-center gap-1 text-sm text-muted hover:text-teal transition-colors mb-8">
          &larr; Back to Home
        </a>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold tracking-tight leading-[1.1] text-white">
          Hexagonal architecture.
          <span class="text-teal">Not accidental spaghetti.</span>
        </h1>
        <p class="mt-6 text-lg md:text-xl text-muted max-w-2xl mx-auto leading-relaxed">
          13 packages, 19 port interfaces, 30+ adapters, strict dependency layering. Every component is testable in isolation, swappable without touching core, and type-safe from config to transport.
        </p>
      </div>
    </section>

    <!-- Stats bar -->
    <section class="px-6 pb-16">
      <div class="max-w-4xl mx-auto">
        <div class="bg-navy-light/80 border border-teal/20 rounded-2xl p-8 md:p-12">
          <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
            <div>
              <p class="text-4xl font-bold text-teal font-mono">13</p>
              <p class="text-muted text-sm mt-2">Packages</p>
            </div>
            <div>
              <p class="text-4xl font-bold text-white font-mono">19</p>
              <p class="text-muted text-sm mt-2">Port interfaces</p>
            </div>
            <div>
              <p class="text-4xl font-bold text-white font-mono">30+</p>
              <p class="text-muted text-sm mt-2">Adapters</p>
            </div>
            <div>
              <p class="text-4xl font-bold text-white font-mono">0</p>
              <p class="text-muted text-sm mt-2">Thrown exceptions</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- What is hexagonal -->
    <section class="px-6 py-16 md:py-24 bg-navy-light/50">
      <div class="max-w-4xl mx-auto">
        <p class="text-teal font-semibold text-sm uppercase tracking-widest mb-4">The idea</p>
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-6">
          Ports define what. Adapters define how.
        </h2>
        <p class="text-muted text-lg mb-8 max-w-2xl leading-relaxed">
          The core defines <span class="text-white font-semibold">port interfaces</span> - what the system needs (send a message, store memory, embed text). Adapters implement those interfaces for specific technologies (Discord, SQLite, OpenAI). The core never knows which adapter is running.
        </p>
        <p class="text-muted text-lg max-w-2xl leading-relaxed">
          A single <span class="text-white font-semibold">composition root</span> (bootstrap.ts) wires everything together at startup. Returns a typed <code class="text-teal bg-navy-light px-2 py-0.5 rounded text-sm font-mono">AppContainer</code> with all services. No singletons, no global state, no service locator.
        </p>
      </div>
    </section>

    <!-- Port table -->
    <section class="px-6 py-16 md:py-24">
      <div class="max-w-5xl mx-auto">
        <p class="text-teal font-semibold text-sm uppercase tracking-widest mb-4">Port interfaces</p>
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-12">
          19 ports, 30+ adapters.
        </h2>

        <div class="space-y-4">
          {ports.map((port) => (
            <div class="bg-navy-light/80 border border-white/5 rounded-xl overflow-hidden">
              <div class="flex flex-col md:flex-row">
                <div class="md:w-48 shrink-0 p-6 flex flex-col justify-center bg-teal/5 border-b md:border-b-0 md:border-r border-white/5">
                  <code class="text-teal font-mono text-sm font-semibold">{port.name}</code>
                  <span class="text-muted text-xs mt-1">{port.adapterCount} adapter{port.adapterCount > 1 ? "s" : ""}</span>
                </div>
                <div class="flex-1 p-6">
                  <p class="text-xs font-medium text-muted uppercase tracking-wider mb-1">Methods</p>
                  <p class="text-muted-light text-sm mb-3 font-mono">{port.methods}</p>
                  <p class="text-xs font-medium text-muted uppercase tracking-wider mb-1">Adapters</p>
                  <p class="text-muted-light text-sm">{port.adapters}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Package dependency graph -->
    <section class="px-6 py-16 md:py-24 bg-navy-light/50">
      <div class="max-w-5xl mx-auto">
        <p class="text-teal font-semibold text-sm uppercase tracking-widest mb-4">Package graph</p>
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-12">
          13 packages in strict layers.
        </h2>

        <div class="overflow-x-auto">
          <table class="w-full text-left">
            <thead>
              <tr class="border-b border-white/10">
                <th scope="col" class="py-3 pr-4 text-sm font-medium text-muted">Package</th>
                <th scope="col" class="py-3 px-4 text-sm font-medium text-muted">Layer</th>
                <th scope="col" class="py-3 px-4 text-sm font-medium text-muted">Purpose</th>
                <th scope="col" class="py-3 pl-4 text-sm font-medium text-muted">Depends on</th>
              </tr>
            </thead>
            <tbody>
              {packages.map((pkg) => (
                <tr class="border-b border-white/5">
                  <td class="py-3 pr-4 text-sm text-teal font-mono font-medium">{pkg.name}</td>
                  <td class="py-3 px-4 text-xs">
                    <span class={`px-2 py-0.5 rounded ${pkg.layer === "Foundation" ? "bg-teal/10 text-teal" : pkg.layer === "Service" ? "bg-coral/10 text-coral" : pkg.layer === "Adapter" ? "bg-purple-500/10 text-purple-400" : "bg-white/5 text-muted"}`}>
                      {pkg.layer}
                    </span>
                  </td>
                  <td class="py-3 px-4 text-sm text-muted">{pkg.desc}</td>
                  <td class="py-3 pl-4 text-sm text-muted-light font-mono text-xs">{pkg.deps}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- Key patterns -->
    <section class="px-6 py-16 md:py-24">
      <div class="max-w-5xl mx-auto">
        <p class="text-teal font-semibold text-sm uppercase tracking-widest mb-4">Key patterns</p>
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-12">
          6 patterns that keep it clean.
        </h2>

        <div class="grid md:grid-cols-2 gap-6">
          {patterns.map((p) => (
            <div class="bg-navy-light/80 border border-white/5 rounded-xl p-6">
              <div class="flex items-center gap-2 mb-3">
                <code class="text-teal font-mono text-sm font-semibold">{p.name}</code>
              </div>
              <p class="text-white text-sm font-medium mb-2">{p.what}</p>
              <p class="text-muted text-sm leading-relaxed mb-3">{p.why}</p>
              <p class="text-xs font-mono text-muted-light bg-navy/50 rounded px-3 py-2">{p.example}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Why it matters -->
    <section class="px-6 py-16 md:py-24 bg-navy-light/50">
      <div class="max-w-5xl mx-auto">
        <p class="text-coral font-semibold text-sm uppercase tracking-widest mb-4">Why it matters</p>
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-12">
          Architecture pays dividends at scale.
        </h2>

        <div class="grid md:grid-cols-2 gap-8">
          {benefits.map((b) => (
            <div class="flex gap-4">
              <div class="shrink-0 w-10 h-10 rounded-lg bg-teal/10 flex items-center justify-center">
                <svg class="w-5 h-5 text-teal" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d={b.icon} />
                </svg>
              </div>
              <div>
                <p class="text-white font-semibold mb-1">{b.title}</p>
                <p class="text-muted text-sm leading-relaxed">{b.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="px-6 py-16 md:py-24">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">
          Read the code. It speaks for itself.
        </h2>
        <p class="text-muted text-lg mb-10">
          Apache-2.0-licensed TypeScript monorepo. Every function returns a typed Result. Every port has a test suite. Every package has a clear responsibility.
        </p>

        <div class="flex flex-wrap gap-4 justify-center">
          <a href="https://docs.comis.ai" rel="noopener noreferrer" target="_blank" class="inline-flex items-center justify-center px-8 py-3.5 bg-coral-btn hover:bg-coral-btn-hover text-white font-semibold rounded-lg transition-colors text-lg">
            Get Started
          </a>
          <a href="https://github.com/comisai/comis" rel="noopener noreferrer" target="_blank" class="inline-flex items-center justify-center gap-2 px-8 py-3.5 bg-white/10 hover:bg-white/15 text-white font-semibold rounded-lg transition-colors text-lg border border-white/10">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
            View on GitHub
          </a>
          <a href="/" class="inline-flex items-center justify-center px-8 py-3.5 bg-white/10 hover:bg-white/15 text-white font-medium rounded-lg transition-colors border border-white/10">
            Back to Home
          </a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Base>
