---
const rows = [
  { label: "Authentication", them: "Often missing or optional", us: "Required by default, mTLS support", win: true },
  { label: "Prompt injection", them: "No detection", us: "65 patterns across 8 categories, weighted scoring", win: true },
  { label: "Memory safety", them: "Single trust level, poisonable", us: "Trust-partitioned - your words vs. the internet's", win: true },
  { label: "Secrets", them: "Plaintext in config, leaked in logs", us: "AES-256 encrypted, 18 redaction rules", win: true },
  { label: "Tool access", them: "Unchecked - full shell by default", us: "Approval gates, per-agent tool policies, OS-level exec sandbox", win: true },
  { label: "Skill safety", them: "Install and hope", us: "Allowlists, scope isolation", win: true },
  { label: "Network safety", them: "No SSRF protection", us: "Private network + metadata endpoints blocked", win: true },
  { label: "Audit trail", them: "None", us: "Every action logged and classified", win: true },
  { label: "Context management", them: "Truncate and hope", us: "8-layer pipeline: eviction, masking, compaction, rehydration", win: true },
  { label: "Tool overhead", them: "All tool definitions on every turn", us: "Progressive disclosure: lean definitions, just-in-time guides, context-aware deferral", win: true },
  { label: "Small model support", them: "Same bloated context for all models", us: "Model-aware tool presentation: pruned schemas, focused tool sets", win: true },
  { label: "Memory", them: "Session-only, no recall", us: "Persistent semantic search with trust-partitioned RAG", win: true },
  { label: "Budget", them: "Unlimited spend", us: "Three-tier budget guard: per-execution, per-hour, per-day", win: true },
  { label: "Agents", them: "One does everything", us: "A team of specialists", win: true },
  { label: "Channels", them: "Varies", us: "9 platforms, full experience", win: true },
  { label: "Models", them: "Often locked to one provider", us: "Any model, any provider", win: true },
  { label: "Source", them: "Closed or partially open", us: "Fully open source, Apache-2.0", win: true },
];
---

<section class="px-6 py-20 md:py-28 bg-navy-light/50">
  <div class="max-w-4xl mx-auto">
    <p class="text-teal font-semibold text-sm uppercase tracking-widest mb-4">How it compares</p>
    <h2 class="text-3xl md:text-4xl font-bold text-white mb-14">
      Not another chatbot.
    </h2>

    <div class="overflow-x-auto">
      <table class="w-full text-left">
        <thead>
          <tr class="border-b border-white/10">
            <th scope="col" class="py-3 pr-6 text-sm font-medium text-muted"></th>
            <th scope="col" class="py-3 px-6 text-sm font-medium text-muted">Typical AI agents</th>
            <th scope="col" class="py-3 pl-6 text-sm font-semibold text-coral">Comis</th>
          </tr>
        </thead>
        <tbody>
          {rows.map((r) => (
            <tr class="border-b border-white/5">
              <th scope="row" class="py-3.5 pr-6 text-sm font-medium text-white whitespace-nowrap text-left">{r.label}</th>
              <td class="py-3.5 px-6 text-sm text-muted/60">{r.them}</td>
              <td class="py-3.5 pl-6 text-sm text-muted-light font-medium">{r.us}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <div class="text-center mt-10">
      <a href="/compare" class="inline-flex items-center gap-2 text-coral hover:text-coral-dark font-medium transition-colors">
        See the full comparison
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </div>
</section>
