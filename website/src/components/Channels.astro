---
---

<section class="px-6 py-20 md:py-28">
  <div class="max-w-4xl mx-auto text-center">
    <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">
      Lives where you already are.
    </h2>
    <p class="text-muted text-lg mb-12">
      Text, voice, images, files, reactions, threads - full experience on every platform.
    </p>

    <div class="flex flex-wrap items-center justify-center gap-8 md:gap-12">
      <div class="flex flex-col items-center gap-2">
        <img src="https://cdn.simpleicons.org/telegram/26A5E4" class="w-10 h-10" alt="Telegram" />
        <span class="text-sm text-muted">Telegram</span>
      </div>
      <div class="flex flex-col items-center gap-2">
        <img src="https://cdn.simpleicons.org/discord/5865F2" class="w-10 h-10" alt="Discord" />
        <span class="text-sm text-muted">Discord</span>
      </div>
      <div class="flex flex-col items-center gap-2">
        <svg class="w-10 h-10" viewBox="0 0 24 24" fill="none">
          <path d="M5.042 15.165a2.528 2.528 0 0 1-2.52 2.523A2.528 2.528 0 0 1 0 15.165a2.527 2.527 0 0 1 2.522-2.52h2.52v2.52zm1.271 0a2.527 2.527 0 0 1 2.521-2.52 2.527 2.527 0 0 1 2.521 2.52v6.313A2.528 2.528 0 0 1 8.834 24a2.528 2.528 0 0 1-2.521-2.522v-6.313z" fill="#E01E5A"/>
          <path d="M8.834 5.042a2.528 2.528 0 0 1-2.521-2.52A2.528 2.528 0 0 1 8.834 0a2.528 2.528 0 0 1 2.521 2.522v2.52H8.834zm0 1.271a2.528 2.528 0 0 1 2.521 2.521 2.528 2.528 0 0 1-2.521 2.521H2.522A2.528 2.528 0 0 1 0 8.834a2.528 2.528 0 0 1 2.522-2.521h6.312z" fill="#36C5F0"/>
          <path d="M18.956 8.834a2.528 2.528 0 0 1 2.522-2.521A2.528 2.528 0 0 1 24 8.834a2.528 2.528 0 0 1-2.522 2.521h-2.522V8.834zm-1.27 0a2.528 2.528 0 0 1-2.522 2.521 2.527 2.527 0 0 1-2.521-2.521V2.522A2.527 2.527 0 0 1 15.165 0a2.528 2.528 0 0 1 2.522 2.522v6.312z" fill="#2EB67D"/>
          <path d="M15.165 18.956a2.528 2.528 0 0 1 2.522 2.522A2.528 2.528 0 0 1 15.165 24a2.527 2.527 0 0 1-2.521-2.522v-2.522h2.521zm0-1.27a2.527 2.527 0 0 1-2.521-2.522 2.528 2.528 0 0 1 2.521-2.522h6.313A2.528 2.528 0 0 1 24 15.165a2.528 2.528 0 0 1-2.522 2.521h-6.313z" fill="#ECB22E"/>
        </svg>
        <span class="text-sm text-muted">Slack</span>
      </div>
      <div class="flex flex-col items-center gap-2">
        <img src="https://cdn.simpleicons.org/whatsapp/25D366" class="w-10 h-10" alt="WhatsApp" />
        <span class="text-sm text-muted">WhatsApp</span>
      </div>
      <div class="flex flex-col items-center gap-2">
        <img src="https://cdn.simpleicons.org/signal/3A76F0" class="w-10 h-10" alt="Signal" />
        <span class="text-sm text-muted">Signal</span>
      </div>
      <div class="flex flex-col items-center gap-2">
        <img src="https://cdn.simpleicons.org/apple/999999" class="w-10 h-10" alt="iMessage" />
        <span class="text-sm text-muted">iMessage</span>
      </div>
      <div class="flex flex-col items-center gap-2">
        <img src="https://cdn.simpleicons.org/line/00C300" class="w-10 h-10" alt="LINE" />
        <span class="text-sm text-muted">LINE</span>
      </div>
      <div class="flex flex-col items-center gap-2">
        <div class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center text-muted font-mono text-xs">IRC</div>
        <span class="text-sm text-muted">IRC</span>
      </div>
      <div class="flex flex-col items-center gap-2">
        <img src="https://cdn.simpleicons.org/gmail/EA4335" class="w-10 h-10" alt="Email" />
        <span class="text-sm text-muted">Email</span>
      </div>
    </div>
  </div>
</section>
