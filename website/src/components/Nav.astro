---
const currentPath = Astro.url.pathname;
---

<nav id="nav" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
  <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2">
      <img src="/images/comis-logo.png" alt="Comis" class="h-8" />
    </a>

    <!-- Desktop links -->
    <div class="hidden md:flex items-center gap-8">
      <a href="/" class:list={["text-sm font-medium transition-colors", currentPath === "/" ? "text-white" : "text-muted hover:text-white"]}>
        Home
      </a>
      <div class="relative group">
        <button class:list={["text-sm font-medium transition-colors flex items-center gap-1", currentPath.startsWith("/compare") ? "text-white" : "text-muted hover:text-white"]}>
          Compare
          <svg class="w-3 h-3 opacity-50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
        </button>
        <div class="absolute top-full left-0 pt-2 hidden group-hover:block">
          <div class="bg-navy-light border border-white/10 rounded-lg py-2 min-w-[180px] shadow-xl">
            <a href="/compare" class:list={["block px-4 py-2 text-sm transition-colors", currentPath === "/compare" ? "text-white bg-white/5" : "text-muted hover:text-white hover:bg-white/5"]}>
              vs Typical Agents
            </a>
            <a href="/compare/openclaw" class:list={["block px-4 py-2 text-sm transition-colors", currentPath === "/compare/openclaw" ? "text-white bg-white/5" : "text-muted hover:text-white hover:bg-white/5"]}>
              vs OpenClaw
            </a>
          </div>
        </div>
      </div>
      <a href="/blog" class:list={["text-sm font-medium transition-colors", currentPath.startsWith("/blog") ? "text-white" : "text-muted hover:text-white"]}>
        Blog
      </a>
      <a href="https://docs.comis.ai" rel="noopener noreferrer" target="_blank" class="text-sm font-medium text-muted hover:text-white transition-colors">
        Docs
      </a>
      <a href="https://github.com/comisai/comis" rel="noopener noreferrer" target="_blank" class="text-sm font-medium text-muted hover:text-white transition-colors">
        GitHub
      </a>
      <a
        href="https://docs.comis.ai"
        rel="noopener noreferrer"
        target="_blank"
        class="inline-flex items-center justify-center px-4 py-1.5 bg-coral-btn hover:bg-coral-btn-hover text-white text-sm font-semibold rounded-lg transition-colors"
      >
        Get Started
      </a>
    </div>

    <!-- Mobile hamburger -->
    <button id="menu-toggle" class="md:hidden p-2 text-muted hover:text-white transition-colors" aria-label="Toggle menu">
      <svg id="menu-icon" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      <svg id="close-icon" class="w-6 h-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-white/5 bg-navy/95 backdrop-blur-md">
    <div class="px-6 py-4 flex flex-col gap-4">
      <a href="/" class:list={["text-sm font-medium transition-colors", currentPath === "/" ? "text-white" : "text-muted hover:text-white"]}>
        Home
      </a>
      <a href="/compare" class:list={["text-sm font-medium transition-colors", currentPath === "/compare" ? "text-white" : "text-muted hover:text-white"]}>
        Compare
      </a>
      <a href="/compare/openclaw" class:list={["text-sm font-medium transition-colors pl-4", currentPath === "/compare/openclaw" ? "text-white" : "text-muted hover:text-white"]}>
        vs OpenClaw
      </a>
      <a href="/blog" class:list={["text-sm font-medium transition-colors", currentPath.startsWith("/blog") ? "text-white" : "text-muted hover:text-white"]}>
        Blog
      </a>
      <a href="https://docs.comis.ai" rel="noopener noreferrer" target="_blank" class="text-sm font-medium text-muted hover:text-white transition-colors">
        Docs
      </a>
      <a href="https://github.com/comisai/comis" rel="noopener noreferrer" target="_blank" class="text-sm font-medium text-muted hover:text-white transition-colors">
        GitHub
      </a>
      <a
        href="https://docs.comis.ai"
        rel="noopener noreferrer"
        target="_blank"
        class="inline-flex items-center justify-center px-4 py-2 bg-coral-btn hover:bg-coral-btn-hover text-white text-sm font-semibold rounded-lg transition-colors"
      >
        Get Started
      </a>
    </div>
  </div>
</nav>

<script>
  // Mobile menu toggle
  const toggle = document.getElementById("menu-toggle");
  const menu = document.getElementById("mobile-menu");
  const menuIcon = document.getElementById("menu-icon");
  const closeIcon = document.getElementById("close-icon");

  toggle?.addEventListener("click", () => {
    const isOpen = !menu?.classList.contains("hidden");
    menu?.classList.toggle("hidden");
    menuIcon?.classList.toggle("hidden");
    closeIcon?.classList.toggle("hidden");
  });

  // Scroll-based background
  const nav = document.getElementById("nav");
  const onScroll = () => {
    if (window.scrollY > 40) {
      nav?.classList.add("bg-navy/95", "backdrop-blur-md", "border-b", "border-white/5");
    } else {
      nav?.classList.remove("bg-navy/95", "backdrop-blur-md", "border-b", "border-white/5");
    }
  };
  window.addEventListener("scroll", onScroll, { passive: true });
  onScroll();
</script>
