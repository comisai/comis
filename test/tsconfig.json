{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "./dist",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2023",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["**/*.ts"],
  "references": [
    { "path": "../packages/daemon" },
    { "path": "../packages/core" },
    { "path": "../packages/channels" },
    { "path": "../packages/shared" },
    { "path": "../packages/infra" }
  ]
}
