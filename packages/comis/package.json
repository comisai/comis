      "types": "./dist/gateway.d.ts",
      "import": "./dist/gateway.js"
    },
    "./skills": {
      "types": "./dist/skills.d.ts",
      "import": "./dist/skills.js"
    },
    "./scheduler": {
      "types": "./dist/scheduler.d.ts",
      "import": "./dist/scheduler.js"
    },
    "./agent": {
      "types": "./dist/agent.d.ts",
      "import": "./dist/agent.js"
    },
    "./channels": {
      "types": "./dist/channels.d.ts",
      "import": "./dist/channels.js"
    },
    "./cli": {
      "types": "./dist/cli.d.ts",
      "import": "./dist/cli.js"
    },
    "./daemon": {
      "types": "./dist/daemon.d.ts",
      "import": "./dist/daemon.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "prepack": "node scripts/prepack.js",
    "postpack": "node scripts/postpack.js"
  },
  "bundledDependencies": [
    "@comis/shared",
    "@comis/core",
