  "engines": {
    "node": ">=22"
  },
  "files": [
    "dist",
    "node_modules/@comis"
  ],
  "bin": {
    "comis": "./dist/cli-entry.js"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/comisai/comis.git",
    "directory": "packages/comis"
  },
  "homepage": "https://comis.ai",
  "bugs": {
    "url": "https://github.com/comisai/comis/issues"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./shared": {
      "types": "./dist/shared.d.ts",
      "import": "./dist/shared.js"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.js"
    },
    "./infra": {
      "types": "./dist/infra.d.ts",
      "import": "./dist/infra.js"
    },
    "./memory": {
      "types": "./dist/memory.d.ts",
      "import": "./dist/memory.js"
    },
