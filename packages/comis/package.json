{
  "name": "comisai",
  "version": "1.0.29",
  "author": "Moshe Anconina",
  "license": "Apache-2.0",
  "description": "Security-first AI agent platform \u2014 connects AI agents to Discord, Telegram, Slack, WhatsApp, and more",
  "keywords": [
    "comis",
    "ai",
    "agent",
    "chatbot",
    "discord",
    "telegram",
    "slack",
    "whatsapp",
    "signal",
    "imessage",
    "irc",
    "line",
    "mcp",
    "multi-agent",
    "assistant"
  ],
  "publishConfig": {
