      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run"
  },
  "dependencies": {
    "@comis/core": "workspace:*",
    "@comis/shared": "workspace:*",
    "better-sqlite3": "^12.6.2",
    "lru-cache": "^11.2.6",
    "node-llama-cpp": "^3.17.1",
    "openai": "^6.27.0",
    "p-queue": "^9.1.0",
    "sqlite-vec": "0.1.7-alpha.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "typescript": "^5.9.3",
    "vitest": "^4.0.0"
  }
