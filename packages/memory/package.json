{
  "name": "@comis/memory",
  "version": "1.0.0",
  "author": "Moshe Anconina",
  "license": "Apache-2.0",
  "description": "SQLite memory, embeddings, and RAG storage for Comis agents",
  "keywords": ["comis", "ai", "agent", "memory", "sqlite", "rag", "embeddings"],
  "engines": { "node": ">=22" },
  "files": ["dist"],
  "publishConfig": { "access": "public" },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/comisai/comis.git",
    "directory": "packages/memory"
  },
  "homepage": "https://github.com/comisai/comis#readme",
  "bugs": {
    "url": "https://github.com/comisai/comis/issues"
  },
  "exports": {
