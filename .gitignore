# Comis monorepo overrides
# Re-include files ignored by root .gitignore
!pnpm-lock.yaml
!packages/core/
!packages/core/**
!dist/

# Environment files (keep .example files)
.env
.env.*
!.env.example
!.env.docker.example

# Comis-specific ignores
node_modules/
**/node_modules/
coverage/
.DS_Store
**/.DS_Store

# IDE and editor files
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
*.swp
*.swo
*~

# Claude Code working directory
.claude/


.planning/

# Build outputs (each package's dist/ is gitignored, built on CI)
packages/*/dist/
website/dist/
website/.astro/
*.tsbuildinfo

# Integration test artifacts
test/.test-results.json
test/.test-daemon.log
test/config/*.last-good.yaml
# Nested config-git repo created by the test daemon's git-manager
# (configDir = test/config, so initRepo runs `git init` here)
test/config/.git/
test/config/.gitignore

# Playwright test results
**/test-results/

# npm pack output
packages/*/*.tgz

# Private keys and certificates
*.pem
*.key
*.p12
*.pfx

# Database files
*.db
*.sqlite

# Log files
*.log
