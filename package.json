{
  "name": "comis-workspace",
  "private": true,
  "description": "Security-first AI agent platform — connects AI agents to real-time chat channels",
  "author": "Moshe Anconina",
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/comisai/comis.git"
  },
  "homepage": "https://github.com/comisai/comis#readme",
  "bugs": {
    "url": "https://github.com/comisai/comis/issues"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "lint:security": "eslint --config eslint.config.js",
    "test": "vitest",
    "test:integration": "vitest run --config test/vitest.config.ts",
    "test:integration:mock": "TEST_PROVIDER_MODE=mock vitest run --config test/vitest.config.ts",
    "test:integration:real": "vitest run --config test/vitest.config.ts",
    "test:orchestrate": "npx tsx test/orchestrate.ts",
    "test:cleanup": "npx tsx test/support/cleanup-test-artifacts.ts"
  },
  "devDependencies": {
    "@agentclientprotocol/sdk": "^0.15.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "eslint": "^10.0.3",
    "eslint-plugin-security": "^4.0.0",
    "hono": "^4.12.5",
    "pino-pretty": "^13.1.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.0",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "pnpm": {
    "overrides": {
      "tar": ">=7.5.7",
      "@sinclair/typebox": "0.34.49"
    }
  }
}
