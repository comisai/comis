{
  "name": "comis-workspace",
  "private": true,
  "description": "Security-first AI agent platform — connects AI agents to real-time chat channels",
  "author": "Moshe Anconina",
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/comisai/comis.git"
  },
  "homepage": "https://github.com/comisai/comis#readme",
  "bugs": {
    "url": "https://github.com/comisai/comis/issues"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "lint:security": "eslint --config eslint.config.js",
    "test": "vitest",
    "test:integration": "vitest run --config test/vitest.config.ts",
    "test:integration:mock": "TEST_PROVIDER_MODE=mock vitest run --config test/vitest.config.ts",
    "test:integration:real": "vitest run --config test/vitest.config.ts",
    "test:orchestrate": "npx tsx test/orchestrate.ts",
    "test:cleanup": "npx tsx test/support/cleanup-test-artifacts.ts"
  },
  "devDependencies": {
    "@agentclientprotocol/sdk": "^0.19.1",
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "eslint": "^10.0.3",
    "eslint-plugin-security": "^4.0.0",
    "globals": "^17.5.0",
    "hono": "^4.12.14",
    "pino-pretty": "^13.1.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.0",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "pnpm": {
    "overrides": {
      "tar": ">=7.5.7",
      "@sinclair/typebox": "0.34.49",
      "protobufjs": ">=7.5.5",
      "undici": ">=7.24.0",
      "flatted": ">=3.4.2",
      "picomatch": ">=4.0.4",
      "path-to-regexp": ">=8.4.0",
      "lodash": ">=4.18.0",
      "basic-ftp": ">=5.3.0",
      "follow-redirects": ">=1.16.0",
      "axios": ">=1.15.0",
      "brace-expansion": ">=5.0.5",
      "nodemailer": ">=8.0.5",
      "music-metadata": ">=11.12.3",
      "vite": ">=7.3.2"
    }
  }
}
